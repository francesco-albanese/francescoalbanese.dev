---
import "@/styles/global.css";
import { getImage } from "astro:assets";
import { SEO } from "astro-seo";
import profilePicture from "@/assets/profile-picture.jpg";

type Props = {
	title: string;
};

const { title } = Astro.props;

const favicon32 = await getImage({ src: profilePicture, width: 32, height: 32, format: "webp" });
const favicon180 = await getImage({ src: profilePicture, width: 180, height: 180, format: "webp" });

const siteUrl = "https://francescoalbanese.dev";
const description =
	"Lead AI Engineer & Senior Staff Engineer based in London. Specialising in GenAI, LLMs, RAG, agentic workflows, and full-stack concurrent distributed systems.";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Francesco Albanese",
	jobTitle: "Lead AI Engineer",
	url: siteUrl,
	sameAs: [
		"https://github.com/francesco-albanese",
		"https://www.linkedin.com/in/albanesefrancesco/",
	],
	knowsAbout: ["LLMs", "RAG", "Agentic Workflows", "TypeScript", "Python", "AWS", "Terraform"],
	address: {
		"@type": "PostalAddress",
		addressLocality: "London",
		addressCountry: "GB",
	},
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" sizes="32x32" href={favicon32.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={favicon180.src} />
    <meta name="theme-color" content="#1e1f2b" />
    <SEO
      title={title}
      description={description}
      canonical={siteUrl}
      openGraph={{
        basic: {
          title: "Francesco Albanese — Lead AI Engineer",
          type: "website",
          image: `${siteUrl}/og.png`,
          url: siteUrl,
        },
        optional: {
          description,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title: "Francesco Albanese — Lead AI Engineer",
        description,
        image: `${siteUrl}/og.png`,
      }}
      extend={{
        meta: [
          { name: "keywords", content: "AI Engineer, Lead AI Engineer, LLMs, RAG, Agentic Workflows, GenAI, TypeScript, Python, AWS, Terraform, London" },
          { name: "author", content: "Francesco Albanese" },
          { name: "robots", content: "index, follow" },
        ],
      }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-base text-primary font-mono">
    <slot />
  </body>
</html>
